.container {
  padding: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 50rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.settings-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 30rpx;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}

.setting-row + .setting-row {
  border-top: 1rpx solid #f0f0f0;
}

.setting-label {
  font-size: 28rpx;
  color: #666;
}

.setting-value {
  font-size: 28rpx;
  color: #4A90D9;
  padding: 8rpx 16rpx;
  background: #f5f8fc;
  border-radius: 8rpx;
}

.upload-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: #4A90D9;
  color: #fff;
  font-size: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.note-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.note-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.note-info {
  flex: 1;
}

.note-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.note-date {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.note-actions {
  display: flex;
  gap: 16rpx;
}

.play-btn, .delete-btn {
  font-size: 24rpx;
  padding: 0 24rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 8rpx;
}

.play-btn {
  background: #4A90D9;
  color: #fff;
}

.delete-btn {
  background: #f5f5f5;
  color: #999;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #ccc;
  font-size: 28rpx;
}

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
}

.loading-box {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx 80rpx;
  text-align: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #eee;
  border-top: 6rpx solid #4A90D9;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin: 0 auto 30rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.cancel-btn {
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  border-radius: 36rpx;
  background: #f5f5f5;
  color: #666;
}
