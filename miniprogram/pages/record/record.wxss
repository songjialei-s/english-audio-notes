.container {
  padding: 30rpx;
}

.lang-picker {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.lang-value {
  color: #4A90D9;
  margin-left: 10rpx;
}

.record-area {
  text-align: center;
  margin-bottom: 40rpx;
}

.timer {
  font-size: 72rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.btn-group {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.record-btn {
  width: 300rpx;
  height: 120rpx;
  line-height: 120rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  background: #4A90D9;
  color: #fff;
}

.record-btn.recording {
  background: #e74c3c;
}

.pause-btn, .resume-btn {
  width: 200rpx;
  height: 120rpx;
  line-height: 120rpx;
  border-radius: 60rpx;
  font-size: 28rpx;
  background: #f0f0f0;
  color: #666;
}

.result-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.audio-bar {
  display: flex;
  gap: 20rpx;
}

.small-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  background: #f0f0f0;
  color: #666;
}

.small-btn.primary {
  background: #4A90D9;
  color: #fff;
}

.text-area {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.result-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
  margin-bottom: 20rpx;
}

.copy-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  background: #4A90D9;
  color: #fff;
  font-size: 28rpx;
}

.playback-controls {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 30rpx;
  margin-bottom: 30rpx;
}

.control-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  border-radius: 36rpx;
  background: #f0f0f0;
  color: #666;
}

.speed-btn {
  width: 100rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 26rpx;
  border-radius: 36rpx;
  background: #4A90D9;
  color: #fff;
}

.history-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 30rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
}

.history-header .section-title {
  margin-bottom: 0;
}

.toggle-icon {
  font-size: 24rpx;
  color: #4A90D9;
}

.history-list {
  margin-top: 20rpx;
}

.history-empty {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-content {
  flex: 1;
  overflow: hidden;
}

.history-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.history-date {
  font-size: 24rpx;
  color: #666;
}

.history-duration {
  font-size: 24rpx;
  color: #999;
}

.history-text {
  font-size: 26rpx;
  color: #333;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.history-delete {
  padding: 10rpx 20rpx;
  color: #e74c3c;
  font-size: 24rpx;
}

.history-actions {
  margin-top: 20rpx;
  text-align: center;
}

.clear-btn {
  width: 200rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  border-radius: 30rpx;
  background: #f0f0f0;
  color: #666;
}
